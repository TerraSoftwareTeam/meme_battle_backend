APP_IMAGE_TAG=sha-initial

# Docker Compose host ports
APP_EXTERNAL_PORT=8080
POSTGRES_EXTERNAL_PORT=5432

# Database credentials
POSTGRES_USER=testuser
POSTGRES_PASSWORD=pass
POSTGRES_DB=testdb

# Local application database connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_MAX_CONNECTIONS=5
DATABASE_MIN_CONNECTIONS=1

# Local application web service
SERVICE_PORT=8080
SERVICE_HOST=0.0.0.0

# CDN
HACKCLUB_CDN_BASE_URL=https://cdn.hackclub.com
HACKCLUB_CDN_API_KEY=

# RUST_LOG format: crate1=level1,crate2=level2,...
# Controls log filtering per module:
# - info       → default log level for the app
# - sqlx=debug  → shows SQL statements and connection info
# - tower_http=info → middleware-level logs
# - axum::rejection=trace → logs full details for Axum rejections (like validation errors)
RUST_LOG=info,sqlx=debug,tower_http=info,axum::rejection=trace,opentelemetry=info

# jwt
# openssl rand -base64 32
JWT_SECRET_KEY=
HMAC_SECRET_KEY=
ARGON2_SECRET_KEY=
SECRET_SEED_KEY=

# Centrifugo Realtime Configuration
CENTRIFUGO_TOKEN_HMAC_SECRET_KEY=
CENTRIFUGO_API_KEY=
CENTRIFUGO_ADMIN_PASSWORD=
CENTRIFUGO_ADMIN_SECRET=
CENTRIFUGO_API_URL=http://localhost:8000/api

# -------------------------------------------------------
# OpenTelemetry OTLP Exporter
# -------------------------------------------------------

# Jaeger OTLP/HTTP Receiver
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
